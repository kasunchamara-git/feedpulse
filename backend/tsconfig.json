{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",            /* This tells TS where your code lives */
    "outDir": "./dist",           /* This is where compiled code goes */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],        /* Only include files in the src folder */
  "exclude": ["node_modules"]
}